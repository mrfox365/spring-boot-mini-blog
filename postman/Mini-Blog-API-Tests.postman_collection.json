{
  "info": {
    "name": "Mini-Blog API Tests",
    "description": "Автотести для перевірки REST API блогу",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "item": [
    {
      "name": "1. Отримання всіх постів",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response is a valid JSON array\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData).to.be.an('array');",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/blog/posts",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "blog", "posts"]
        }
      }
    },
    {
      "name": "2. Створення нового поста",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200 (Post created)\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"Response contains success message\", function () {",
              "    pm.expect(pm.response.text()).to.include(\"Post created\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "POST",
        "header": [
          {
            "key": "Content-Type",
            "value": "application/json"
          }
        ],
        "body": {
          "mode": "raw",
          "raw": "{\n    \"content\": \"Тестовий пост з Postman!\",\n    \"authorUsername\": \"Fox\"\n}"
        },
        "url": {
          "raw": "http://localhost:8080/api/blog/posts",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "blog", "posts"]
        }
      }
    },
    {
      "name": "3. Отримання профілю користувача",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Status code is 200\", function () {",
              "    pm.response.to.have.status(200);",
              "});",
              "pm.test(\"User has correct username\", function () {",
              "    var jsonData = pm.response.json();",
              "    pm.expect(jsonData.username).to.eql(\"Fox\");",
              "});"
            ],
            "type": "text/javascript"
          }
        }
      ],
      "request": {
        "method": "GET",
        "header": [],
        "url": {
          "raw": "http://localhost:8080/api/profile/Fox",
          "protocol": "http",
          "host": ["localhost"],
          "port": "8080",
          "path": ["api", "profile", "Fox"]
        }
      }
    }
  ]
}